        "price = 110\n",
        "tax = 10\n",
        "\n",
        "def tax_total(price: int, tax: float) -> float:\n",
        "  total = price + (price * tax / 100)\n",
        "  return total\n",
        "\n",
        "result = tax_total(price, tax)\n",
        "print(result)\n"
      ]
